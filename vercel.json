{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/provider-generate.js": {
      "maxDuration": 300
    },
    "api/fal/lora-img2img.js": {
      "maxDuration": 300
    },
    "api/library-list.js": {
      "maxDuration": 300
    },
    "api/r2-presign.js": {
      "maxDuration": 30
    },
    "api/provider-key-test.js": {
      "maxDuration": 30
    },
    "api/replicate/predictions/index.ts": {
      "maxDuration": 60
    },
    "api/replicate/predictions/[id].ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
